---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Background from '../components/Background.vue';

interface Props {
  title: string;
  description?: string;
  hideHeader?: boolean;
}

const { title, description = "A personal blog and component showcase", hideHeader = false } = Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-transparent text-text-base min-h-screen flex flex-col relative overflow-x-hidden selection:bg-primary-500 selection:text-white">
    <Background client:only="vue" />
    {!hideHeader && <Header />}
    <main class="flex-grow flex flex-col pt-16">
      <slot />
    </main>
    <footer class="py-8 text-center text-text-muted border-t border-bg-surface mt-12 z-10 bg-bg-base/50 backdrop-blur-sm">
      <p>&copy; {new Date().getFullYear()} My Blog. All rights reserved.</p>
    </footer>
  </body>
</html>
