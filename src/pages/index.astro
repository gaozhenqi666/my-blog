---
import Layout from '../layouts/Layout.astro';
import IntroAnimation from '../components/IntroAnimation.vue';
---

<Layout title="Overthinker - 个人博客">
  <!-- 客户端加载 GSAP 开场动画 -->
  <IntroAnimation client:only="vue" />

  <!-- Hero Section -->
  <section class="flex flex-col items-center justify-center pt-24 pb-12 relative overflow-hidden z-10">
    <div class="max-w-4xl mx-auto px-4 text-center relative z-10">
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 text-white drop-shadow-lg">
        Hi, I'm <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-400 to-blue-400">Overthinker</span>
      </h1>
      <p class="text-xl md:text-2xl text-text-muted mb-10 max-w-2xl mx-auto leading-relaxed">
        “无所谓，跳探戈不像人生，一步跳错了，继续跳就行了”
      </p>
      
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/blog" class="px-8 py-3 bg-primary-600/90 hover:bg-primary-500 backdrop-blur-sm text-white rounded-full font-medium transition-all shadow-[0_0_20px_rgba(147,51,234,0.3)] hover:shadow-[0_0_30px_rgba(147,51,234,0.5)]">
          阅读文章
        </a>
        <a href="/components" class="px-8 py-3 bg-bg-surface/50 hover:bg-bg-surface-hover/80 backdrop-blur-sm border border-primary-500/20 text-white rounded-full font-medium transition-all">
          组件展示
        </a>
      </div>
    </div>
  </section>

  <!-- Main Content Layout -->
  <div class="max-w-7xl mx-auto px-4 py-8 flex flex-col lg:flex-row gap-8 items-start relative z-10">
    
    <!-- Left Sidebar: Profile & Skills -->
    <aside class="w-full lg:w-1/4 flex flex-col gap-6 lg:sticky lg:top-24 max-h-[calc(100vh-8rem)] overflow-y-auto custom-scrollbar pr-2 pb-8">
      <!-- Profile Card -->
      <div class="bg-bg-surface/40 backdrop-blur-md border border-bg-surface rounded-2xl p-6 shadow-xl">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-16 h-16 rounded-full bg-gradient-to-br from-primary-500 to-blue-500 flex items-center justify-center text-white text-xl font-bold">
            OT
          </div>
          <div>
            <h3 class="text-xl font-bold text-white">Overthinker</h3>
            <p class="text-sm text-text-muted">前端开发 / 造轮子爱好者</p>
          </div>
        </div>
        <p class="text-sm text-text-muted mb-4">
          一个在大学的海洋中挣扎求生的过度思考者，正在将屎山雕琢成艺术品的路上...
        </p>
        <div class="flex gap-2">
          <a href="https://github.com" target="_blank" class="p-2 bg-bg-base/50 rounded-lg hover:text-primary-400 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </a>
        </div>
      </div>

      <!-- Skills Card -->
      <div class="bg-bg-surface/40 backdrop-blur-md border border-bg-surface rounded-2xl p-6 shadow-xl">
        <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
          <span class="w-1.5 h-4 bg-primary-500 rounded-full"></span> 技术栈
        </h3>
        <div class="flex flex-wrap gap-2">
          {['Vue 3', 'Astro', 'TypeScript', 'Tailwind', 'GSAP', 'C++'].map(skill => (
            <span class="px-2.5 py-1 text-xs font-medium bg-primary-500/10 text-primary-300 border border-primary-500/20 rounded-md">
              {skill}
            </span>
          ))}
        </div>
      </div>
      
      <!-- Categories Card -->
      <div class="bg-bg-surface/40 backdrop-blur-md border border-bg-surface rounded-2xl p-6 shadow-xl">
        <h3 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
          <span class="w-1.5 h-4 bg-primary-500 rounded-full"></span> 分类
        </h3>
        <div class="space-y-2">
          <a href="#" class="flex justify-between items-center text-sm text-text-muted hover:text-primary-400 transition-colors">
            <span>前端开发</span>
            <span class="px-2 py-0.5 bg-bg-base/50 rounded-md text-xs">12</span>
          </a>
          <a href="#" class="flex justify-between items-center text-sm text-text-muted hover:text-primary-400 transition-colors">
            <span>数据结构与算法</span>
            <span class="px-2 py-0.5 bg-bg-base/50 rounded-md text-xs">8</span>
          </a>
          <a href="#" class="flex justify-between items-center text-sm text-text-muted hover:text-primary-400 transition-colors">
            <span>生活随笔</span>
            <span class="px-2 py-0.5 bg-bg-base/50 rounded-md text-xs">5</span>
          </a>
        </div>
      </div>
    </aside>

    <!-- Center Content: Recent Posts & Archives -->
    <main class="w-full lg:w-1/2 flex flex-col gap-6 pb-8" id="main-content">
      <div id="posts-container" class="flex flex-col gap-6">
        <div class="bg-bg-surface/40 backdrop-blur-md border border-bg-surface rounded-2xl p-6 shadow-xl mb-2 flex items-center justify-between">
          <h2 class="text-xl font-bold text-white flex items-center gap-3">
            <span class="w-2 h-6 bg-primary-500 rounded-full"></span>
            最近文章
          </h2>
          <a href="/blog" class="text-sm text-primary-400 hover:text-primary-300 transition-colors">查看全部 →</a>
        </div>
        
        <a href="/blog/priority-queue" class="group block p-6 rounded-2xl bg-bg-surface/60 backdrop-blur-md border border-bg-surface hover:border-primary-500/50 transition-all shadow-xl">
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-xl font-bold text-white group-hover:text-primary-400 transition-colors">⚡ 优先级队列（堆！堆！堆！）</h3>
          </div>
          <p class="text-text-muted mb-6 line-clamp-3 leading-relaxed">
            本文将系统性地介绍优先级队列（Priority Queue）就是这样一个不讲武德的数据结构，它不遵循FIFO（先进先出），而是谁优先级高谁先出。
          </p>
          <div class="flex items-center justify-between text-xs text-text-muted">
            <div class="flex items-center gap-4">
              <span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg> 2025-08-12</span>
              <span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg> 1681 字</span>
            </div>
            <div class="flex gap-2">
              <span class="px-2 py-1 bg-primary-500/10 text-primary-400 rounded-md">数据结构</span>
            </div>
          </div>
        </a>
        
        <a href="/blog/binary-tree" class="group block p-6 rounded-2xl bg-bg-surface/60 backdrop-blur-md border border-bg-surface hover:border-primary-500/50 transition-all shadow-xl">
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-xl font-bold text-white group-hover:text-primary-400 transition-colors">🌳二叉树从基础概念到应用实践</h3>
          </div>
          <p class="text-text-muted mb-6 line-clamp-3 leading-relaxed">
            本文将系统性地介绍二叉树的核心知识点，包括基本概念、性质、存储方式、遍历方法以及常见面试题解析。
          </p>
          <div class="flex items-center justify-between text-xs text-text-muted">
            <div class="flex items-center gap-4">
              <span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg> 2025-04-27</span>
              <span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg> 1362 字</span>
            </div>
            <div class="flex gap-2">
              <span class="px-2 py-1 bg-primary-500/10 text-primary-400 rounded-md">算法</span>
            </div>
          </div>
        </a>
      </div>

      <!-- Archives Section (Hidden by default) -->
      <div id="archives-content" class="hidden">
        <div class="bg-bg-surface/40 backdrop-blur-md border border-bg-surface rounded-2xl p-6 shadow-xl mb-6">
          <h2 class="text-xl font-bold text-white flex items-center gap-3 mb-6">
            <span class="w-2 h-6 bg-primary-500 rounded-full"></span>
            归档目录
          </h2>
          
          <div class="space-y-8 relative before:absolute before:inset-0 before:ml-2 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-bg-surface before:to-transparent">
            <!-- Timeline Item -->
            <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
              <div class="flex items-center justify-center w-5 h-5 rounded-full border-2 border-primary-500 bg-bg-base shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 shadow-primary-500/50"></div>
              <div class="w-[calc(100%-2rem)] md:w-[calc(50%-1.5rem)] p-4 rounded-xl border border-bg-surface bg-bg-surface/40 backdrop-blur-sm hover:border-primary-500/30 transition-colors shadow-xl">
                <div class="flex items-center justify-between mb-2">
                  <h4 class="font-bold text-white">2025年 8月</h4>
                </div>
                <ul class="space-y-3">
                  <li>
                    <a href="/blog/priority-queue" class="text-text-muted hover:text-primary-400 transition-colors block">
                      <span class="text-xs mr-2 text-primary-300">08-12</span>
                      ⚡ 优先级队列（堆！堆！堆！）
                    </a>
                  </li>
                </ul>
              </div>
            </div>
            
            <!-- Timeline Item -->
            <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
              <div class="flex items-center justify-center w-5 h-5 rounded-full border-2 border-bg-surface-hover bg-bg-base shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 group-hover:border-primary-400 transition-colors"></div>
              <div class="w-[calc(100%-2rem)] md:w-[calc(50%-1.5rem)] p-4 rounded-xl border border-bg-surface bg-bg-surface/40 backdrop-blur-sm hover:border-primary-500/30 transition-colors shadow-xl">
                <div class="flex items-center justify-between mb-2">
                  <h4 class="font-bold text-white">2025年 4月</h4>
                </div>
                <ul class="space-y-3">
                  <li>
                    <a href="/blog/binary-tree" class="text-text-muted hover:text-primary-400 transition-colors block">
                      <span class="text-xs mr-2 text-primary-300">04-27</span>
                      🌳二叉树从基础概念到应用实践
                    </a>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Right Sidebar: Calendar & Terminal -->
    <aside class="w-full lg:w-1/4 flex flex-col gap-6 lg:sticky lg:top-24 max-h-[calc(100vh-8rem)] overflow-y-auto custom-scrollbar pl-2 pb-8">
      <!-- Calendar Widget -->
      <div class="bg-bg-surface/40 backdrop-blur-md border border-bg-surface rounded-2xl p-5 shadow-xl">
        <div class="flex justify-between items-center mb-4">
          <button class="text-text-muted hover:text-white">&lt;</button>
          <span class="font-bold text-white">December 2025</span>
          <button class="text-text-muted hover:text-white">&gt;</button>
        </div>
        <div class="grid grid-cols-7 gap-1 text-center text-xs mb-2">
          <span class="text-primary-400">Sun</span>
          <span>Mon</span>
          <span>Tue</span>
          <span>Wed</span>
          <span>Thu</span>
          <span>Fri</span>
          <span class="text-primary-400">Sat</span>
        </div>
        <div class="grid grid-cols-7 gap-1 text-center text-sm">
          <!-- Calendar Days (Mock) -->
          <span class="p-1 text-text-muted/30">30</span>
          <span class="p-1 hover:bg-bg-surface rounded-full cursor-pointer transition-colors">1</span>
          <span class="p-1 hover:bg-bg-surface rounded-full cursor-pointer transition-colors">2</span>
          <span class="p-1 hover:bg-bg-surface rounded-full cursor-pointer transition-colors">3</span>
          <span class="p-1 hover:bg-bg-surface rounded-full cursor-pointer transition-colors">4</span>
          <span class="p-1 hover:bg-bg-surface rounded-full cursor-pointer transition-colors">5</span>
          <span class="p-1 hover:bg-bg-surface rounded-full cursor-pointer transition-colors">6</span>
          
          <span class="p-1 hover:bg-bg-surface rounded-full cursor-pointer transition-colors">7</span>
          <span class="p-1 bg-primary-500/20 text-primary-400 font-bold rounded-full cursor-pointer border border-primary-500/30">8</span>
          <span class="p-1 hover:bg-bg-surface rounded-full cursor-pointer transition-colors">9</span>
          <span class="p-1 hover:bg-bg-surface rounded-full cursor-pointer transition-colors">10</span>
          <span class="p-1 hover:bg-bg-surface rounded-full cursor-pointer transition-colors">11</span>
          <span class="p-1 hover:bg-bg-surface rounded-full cursor-pointer transition-colors">12</span>
          <span class="p-1 hover:bg-bg-surface rounded-full cursor-pointer transition-colors">13</span>
        </div>
      </div>

      <!-- Terminal Emulator Section -->
      <div class="rounded-2xl overflow-hidden border border-bg-surface bg-[#0d0d0f]/80 backdrop-blur-md shadow-xl flex flex-col">
        <div class="flex items-center px-4 py-2 bg-bg-surface/60 border-b border-bg-surface/50 shrink-0">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
          </div>
          <div class="mx-auto text-xs text-text-muted font-mono">terminal</div>
        </div>
        <div class="p-4 font-mono text-xs h-48 overflow-y-auto custom-scrollbar" id="terminal-container">
          <p class="text-primary-400 mb-1">$ Welcome to Overthinker-Blog</p>
          <p class="text-text-muted mb-3">$ Type 'help' to see available commands</p>
          
          <div id="terminal-output"></div>
          
          <div class="flex items-center mt-2">
            <span class="text-green-400 mr-2">➜</span>
            <span class="text-primary-300 mr-2">~</span>
            <form id="terminal-form" class="flex-1 flex" onsubmit="event.preventDefault();">
              <input 
                type="text" 
                id="terminal-input" 
                class="bg-transparent border-none outline-none text-white flex-1 w-full focus:ring-0 p-0 text-xs"
                autocomplete="off"
              />
            </form>
          </div>
        </div>
      </div>
    </aside>
  </div>
</Layout>
