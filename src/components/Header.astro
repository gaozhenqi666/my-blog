---
const navItems = [
  { label: '首页', href: '/', id: 'nav-home' },
  { label: '归档', href: '#', id: 'nav-archives' },
  { label: '文章', href: '/blog', id: 'nav-blog' },
  { label: '组件', href: '/components', id: 'nav-components' },
  { label: '关于', href: '/about', id: 'nav-about' },
];
---

<header class="fixed top-0 left-0 right-0 z-40 bg-bg-base/80 backdrop-blur-md border-b border-bg-surface transition-all duration-300">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="text-xl font-bold tracking-tighter text-white hover:text-primary-400 transition-colors">
      OVER<span class="text-primary-500">THINKER</span>
    </a>
    
    <nav class="hidden md:flex items-center gap-6">
      {navItems.map(item => (
        <a 
          href={item.href} 
          id={item.id}
          class="text-sm font-medium text-text-muted hover:text-white transition-colors relative group nav-link"
        >
          {item.label}
          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary-500 transition-all group-hover:w-full"></span>
        </a>
      ))}
    </nav>
    
    <div class="flex items-center gap-4">
      <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      </a>
      <button id="mobile-menu-btn" class="md:hidden text-text-muted hover:text-white">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-bg-base border-b border-bg-surface">
    <nav class="flex flex-col px-4 py-4 space-y-4">
      {navItems.map(item => (
        <a 
          href={item.href} 
          id={`${item.id}-mobile`}
          class="text-sm font-medium text-text-muted hover:text-white transition-colors nav-link"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }

  // Handle SPA-like navigation for Home and Archives on index page
  document.addEventListener('DOMContentLoaded', () => {
    const isHomePage = window.location.pathname === '/';
    
    if (isHomePage) {
      const homeLinks = document.querySelectorAll('#nav-home, #nav-home-mobile');
      const archiveLinks = document.querySelectorAll('#nav-archives, #nav-archives-mobile');
      const postsContainer = document.getElementById('posts-container');
      const archivesContainer = document.getElementById('archives-content');
      
      const switchTab = (showArchives: boolean) => {
        if (!postsContainer || !archivesContainer) return;
        
        if (showArchives) {
          postsContainer.classList.add('hidden');
          archivesContainer.classList.remove('hidden');
        } else {
          postsContainer.classList.remove('hidden');
          archivesContainer.classList.add('hidden');
        }
      };

      archiveLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          switchTab(true);
          if (menu && !menu.classList.contains('hidden')) {
            menu.classList.add('hidden');
          }
        });
      });

      homeLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          // If we're already on home, just switch the tab content instead of reloading
          e.preventDefault();
          switchTab(false);
          if (menu && !menu.classList.contains('hidden')) {
            menu.classList.add('hidden');
          }
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      });
    } else {
      // If not on home page, make the Archives link go to home page with a hash
      const archiveLinks = document.querySelectorAll('#nav-archives, #nav-archives-mobile');
      archiveLinks.forEach(link => {
        link.setAttribute('href', '/#archives');
      });
    }
  });

  // Handle hash navigation on load
  window.addEventListener('load', () => {
    if (window.location.hash === '#archives' && window.location.pathname === '/') {
      const postsContainer = document.getElementById('posts-container');
      const archivesContainer = document.getElementById('archives-content');
      if (postsContainer && archivesContainer) {
        postsContainer.classList.add('hidden');
        archivesContainer.classList.remove('hidden');
      }
    }
  });
</script>
